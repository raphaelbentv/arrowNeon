---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Page introuvable — Arrow" description="Cette page n'existe pas ou a été déplacée." activePage="">
  <div class="main-container">
    <div class="cyber-header" style="min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
      <p class="eyebrow" style="color: var(--accent-cyan); letter-spacing: 0.3em; font-size: 0.85rem; margin-bottom: 1rem;">ERREUR</p>
      <h1 class="cyber-logo" style="font-size: clamp(5rem, 20vw, 12rem); line-height: 1; margin-bottom: 0.5rem;">404</h1>
      <p class="cyber-tagline" style="margin-bottom: 2rem;">PAGE INTROUVABLE</p>
      <p style="color: var(--muted-foreground); max-width: 420px; margin-bottom: 2.5rem; line-height: 1.6;">
        Cette page n'existe pas ou a été déplacée. Revenez à l'accueil ou explorez nos fonctionnalités.
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
        <a href="/" class="btn-primary">Retour à l'accueil</a>
        <a href="/contact" class="btn-ghost">Nous contacter</a>
      </div>
    </div>
  </div>
</BaseLayout>
