---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getBlogPosts, getBlogPost } from '../../lib/sanity'
import { PortableText } from '@portabletext/react'

export async function getStaticPaths() {
  const posts = await getBlogPosts()
  return posts.map((post: any) => ({ params: { slug: post.slug.current } }))
}

const { slug } = Astro.params
const post = await getBlogPost(slug as string)
if (!post) return Astro.redirect('/blog')
---
<BaseLayout title={`${post.title} — Arrow`} activePage="blog">
  <div class="main-container">
    <article class="blog-post">
      <header class="blog-post-header">
        <a href="/blog" class="blog-back">← Retour au blog</a>
        {post.coverImage && <img src={post.coverImage} alt={post.title} class="blog-post-cover" />}
        <div class="blog-post-meta">
          {post.tags?.map((tag: string) => <span class="blog-tag">{tag}</span>)}
          <span class="blog-post-date">{new Date(post.publishedAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        </div>
        <h1 class="blog-post-title">{post.title}</h1>
        {post.excerpt && <p class="blog-post-excerpt">{post.excerpt}</p>}
        {post.author && <p class="blog-post-author">Par {post.author}</p>}
      </header>
      <div class="blog-post-body">
        <PortableText value={post.body} client:load />
      </div>
    </article>
  </div>
</BaseLayout>
