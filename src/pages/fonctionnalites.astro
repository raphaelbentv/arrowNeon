---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Fonctionnalités — Arrow" activePage="fonctionnalites">
  <div class="main-container">
    <div class="cyber-header">
      <h1 class="cyber-logo">FONCTIONNALITÉS</h1>
      <p class="cyber-tagline">TOUS LES MODULES POUR GÉRER VOTRE ÉTABLISSEMENT</p>
    </div>

    <!-- Module Sections -->
    <div class="modules-container">
      <div class="modules-grid">
        <!-- Authentification -->
        <div class="card module-card">
          <div class="module-icon">🔐</div>
          <h2 class="card-title">AUTHENTIFICATION</h2>
          <div class="card-content">
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices pédagogiques</h3>
              <ul class="module-benefits-list">
                <li>Accès sécurisé pour élèves, enseignants et parents</li>
                <li>Tableau de bord personnalisé selon le profil</li>
                <li>Historique des connexions et activités</li>
              </ul>
            </div>
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices administratifs</h3>
              <ul class="module-benefits-list">
                <li>Gestion centralisée des accès</li>
                <li>Conformité RGPD intégrée</li>
                <li>Authentification à deux facteurs disponible</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Cours -->
        <div class="card module-card">
          <div class="module-icon">📚</div>
          <h2 class="card-title">COURS</h2>
          <div class="card-content">
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices pédagogiques</h3>
              <ul class="module-benefits-list">
                <li>Création et gestion de cours en ligne</li>
                <li>Ressources pédagogiques centralisées</li>
                <li>Suivi de progression par élève</li>
              </ul>
            </div>
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices administratifs</h3>
              <ul class="module-benefits-list">
                <li>Planification automatique des cours</li>
                <li>Gestion des salles et matériel</li>
                <li>Export des plannings</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Évaluations -->
        <div class="card module-card">
          <div class="module-icon">📝</div>
          <h2 class="card-title">ÉVALUATIONS</h2>
          <div class="card-content">
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices pédagogiques</h3>
              <ul class="module-benefits-list">
                <li>Création d'évaluations numériques</li>
                <li>Correction automatisée</li>
                <li>Statistiques de performance</li>
              </ul>
            </div>
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices administratifs</h3>
              <ul class="module-benefits-list">
                <li>Génération automatique de bulletins</li>
                <li>Archivage sécurisé des notes</li>
                <li>Conformité Qualiopi</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Messagerie -->
        <div class="card module-card">
          <div class="module-icon">💬</div>
          <h2 class="card-title">MESSAGERIE</h2>
          <div class="card-content">
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices pédagogiques</h3>
              <ul class="module-benefits-list">
                <li>Communication directe enseignant-élève</li>
                <li>Notifications en temps réel</li>
                <li>Partage de fichiers et ressources</li>
              </ul>
            </div>
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices administratifs</h3>
              <ul class="module-benefits-list">
                <li>Communication centralisée</li>
                <li>Historique des échanges</li>
                <li>Alertes automatiques</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Planning -->
        <div class="card module-card">
          <div class="module-icon">📅</div>
          <h2 class="card-title">PLANNING</h2>
          <div class="card-content">
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices pédagogiques</h3>
              <ul class="module-benefits-list">
                <li>Emplois du temps interactifs</li>
                <li>Notifications de changements</li>
                <li>Accès mobile optimisé</li>
              </ul>
            </div>
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices administratifs</h3>
              <ul class="module-benefits-list">
                <li>Génération automatique des plannings</li>
                <li>Gestion des conflits</li>
                <li>Optimisation des ressources</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Alternance -->
        <div class="card module-card">
          <div class="module-icon">🤝</div>
          <h2 class="card-title">ALTERNANCE</h2>
          <div class="card-content">
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices pédagogiques</h3>
              <ul class="module-benefits-list">
                <li>Suivi des stages et alternances</li>
                <li>Évaluation des compétences</li>
                <li>Portfolio numérique</li>
              </ul>
            </div>
            <div class="module-benefits-section">
              <h3 class="benefits-subtitle">Bénéfices administratifs</h3>
              <ul class="module-benefits-list">
                <li>Gestion des contrats</li>
                <li>Suivi des entreprises partenaires</li>
                <li>Conformité légale</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
