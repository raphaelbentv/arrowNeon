---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Tarifs — Arrow" activePage="tarifs">
  <div class="main-container">
    <div class="cyber-header">
      <h1 class="cyber-logo">TARIFS</h1>
      <p class="cyber-tagline">TARIFICATION FLEXIBLE SELON VOS BESOINS</p>
    </div>

    <div class="pricing-container">
      <div class="pricing-grid">
        <!-- Starter -->
        <div class="pricing-card">
          <div class="pricing-header">
            <h3 class="pricing-title">STARTER</h3>
            <div class="pricing-price">
              <span class="price-amount">À partir de</span>
              <span class="price-value">299€</span>
              <span class="price-period">/mois</span>
            </div>
            <p class="pricing-subtitle">Jusqu'à 50 étudiants</p>
          </div>
          <div class="pricing-features">
            <ul>
              <li>✓ Tous les modules de base</li>
              <li>✓ Support par email</li>
              <li>✓ Mises à jour incluses</li>
              <li>✓ Hébergement sécurisé</li>
              <li>✓ Formation initiale</li>
            </ul>
          </div>
          <div class="pricing-cta">
            <a href="/contact" class="btn-primary">Demander un devis</a>
          </div>
        </div>

        <!-- Professional -->
        <div class="pricing-card featured">
          <div class="pricing-badge">POPULAIRE</div>
          <div class="pricing-header">
            <h3 class="pricing-title">PROFESSIONAL</h3>
            <div class="pricing-price">
              <span class="price-amount">À partir de</span>
              <span class="price-value">599€</span>
              <span class="price-period">/mois</span>
            </div>
            <p class="pricing-subtitle">Jusqu'à 200 étudiants</p>
          </div>
          <div class="pricing-features">
            <ul>
              <li>✓ Tous les modules avancés</li>
              <li>✓ Support prioritaire</li>
              <li>✓ Personnalisation</li>
              <li>✓ API et intégrations</li>
              <li>✓ Formation continue</li>
              <li>✓ Gestionnaire de compte dédié</li>
            </ul>
          </div>
          <div class="pricing-cta">
            <a href="/contact" class="btn-primary">Demander un devis</a>
          </div>
        </div>

        <!-- Enterprise -->
        <div class="pricing-card">
          <div class="pricing-header">
            <h3 class="pricing-title">ENTERPRISE</h3>
            <div class="pricing-price">
              <span class="price-amount">Sur mesure</span>
              <span class="price-value">—</span>
            </div>
            <p class="pricing-subtitle">Plus de 200 étudiants</p>
          </div>
          <div class="pricing-features">
            <ul>
              <li>✓ Solution sur mesure</li>
              <li>✓ Support 24/7</li>
              <li>✓ Développements personnalisés</li>
              <li>✓ Hébergement dédié</li>
              <li>✓ Formation sur site</li>
              <li>✓ SLA garanti</li>
            </ul>
          </div>
          <div class="pricing-cta">
            <a href="/contact" class="btn-primary">Nous contacter</a>
          </div>
        </div>
      </div>

      <div class="pricing-note">
        <p>💡 <strong>Tarification personnalisée disponible</strong> - Contactez-nous pour un devis adapté à votre établissement</p>
      </div>
    </div>
  </div>
</BaseLayout>
