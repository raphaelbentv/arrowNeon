                      <td><span class="hp-email-link">maxime.andre@email.com</span></td>
                      <td>51h00 (17)</td>
                      <td>18h00 (6)</td>
                      <td><span class="hp-status">Début d'année</span></td>
                      <td></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="comparison-side side-arrow">
            <div class="arrow-interface">

              <!-- Navigation fidèle au vrai Arrow -->
              <div class="arrow-mini-nav">
                <div class="arrow-mini-brand">
                  <span class="arrow-mini-logo">ARROW</span>
                  <span class="arrow-mini-school">ARROW DEMO CAMPUS</span>
                </div>
                <div class="arrow-mini-tabs">
                  <span class="arrow-mini-tab">MON ESPACE</span>
                  <span class="arrow-mini-tab">PLANNING</span>
                  <span class="arrow-mini-tab">PÉDAGOGIE</span>
                  <span class="arrow-mini-tab">UTILISATEURS</span>
                  <span class="arrow-mini-tab">COMMUNICATION</span>
                  <span class="arrow-mini-tab">SUIVIS</span>
                  <span class="arrow-mini-tab">PARAMÈTRES</span>
                </div>
              </div>

              <!-- Dashboard — vue Synthèse fidèle au vrai Arrow -->
              <div class="arrow-page-content">
                <p class="arrow-greeting">Bonjour <span class="arrow-greeting__name">Admin</span></p>

                <!-- Onglets dashboard -->
                <div class="arrow-dashboard-tabs">
                  <span class="arrow-dtab arrow-dtab--active">SYNTHÈSE</span>
                  <span class="arrow-dtab">PLANNING</span>
                  <span class="arrow-dtab">ÉTUDIANTS</span>
                  <span class="arrow-dtab">INTERVENANTS</span>
                  <span class="arrow-dtab">MODULES</span>
                  <span class="arrow-dtab">PRÉSENCES</span>
                  <span class="arrow-dtab">ÉVALUATIONS</span>
                  <span class="arrow-dtab">EXPORTS</span>
                </div>

                <!-- 6 stats clés du dashboard réel -->
                <div class="arrow-kpi-grid">
                  <div class="arrow-kpi-card">
                    <span class="arrow-kpi-label">ÉTUDIANTS</span>
                    <span class="arrow-kpi-value arrow-kpi--pink">82</span>
                  </div>
                  <div class="arrow-kpi-card">
                    <span class="arrow-kpi-label">INTERVENANTS</span>
                    <span class="arrow-kpi-value arrow-kpi--purple">12</span>
                  </div>
                  <div class="arrow-kpi-card">
                    <span class="arrow-kpi-label">COHORTES</span>
                    <span class="arrow-kpi-value arrow-kpi--cyan">6</span>
                  </div>
                  <div class="arrow-kpi-card">
                    <span class="arrow-kpi-label">MODULES</span>
                    <span class="arrow-kpi-value arrow-kpi--orange">24</span>
                  </div>
                  <div class="arrow-kpi-card">
                    <span class="arrow-kpi-label">ÉVALUATIONS</span>
                    <span class="arrow-kpi-value arrow-kpi--pink">15</span>
                  </div>
                  <div class="arrow-kpi-card">
                    <span class="arrow-kpi-label">MOYENNE</span>
                    <span class="arrow-kpi-value arrow-kpi--green">13.4</span>
                  </div>
                </div>

                <!-- Points d'attention — section clé du vrai dashboard -->
                <div class="arrow-alerts-section">
                  <p class="arrow-alerts-title">POINTS D'ATTENTION</p>
                  <div class="arrow-alert-row">
                    <div class="arrow-alert-content">
                      <span class="arrow-alert-name">Inactifs 14j+</span>
                      <span class="arrow-alert-desc">3 étudiant(s) sans activité depuis plus de 14 jours</span>
                    </div>
                    <span class="arrow-alert-count arrow-kpi--orange">3</span>
                  </div>
                  <div class="arrow-alert-row">
                    <div class="arrow-alert-content">
                      <span class="arrow-alert-name">Bulletins à valider</span>
                      <span class="arrow-alert-desc">5 bulletins en attente de signature</span>
                    </div>
                    <span class="arrow-alert-count arrow-kpi--orange">5</span>
                  </div>
                </div>

                <!-- CTA repris du vrai Arrow -->
                <div class="arrow-demo-cta">
                  <span class="arrow-demo-cta__text">Vous voulez voir Arrow sur vos données réelles ?</span>
                  <button class="arrow-demo-cta__btn">Demander une démo</button>
                </div>
              </div>
            </div>
          </div>

          <button
            type="button"
            class="slider-handle"
            id="sliderHandle"
            role="slider"
            aria-label="Comparer une vue dispersée et Arrow"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="50"
            aria-valuetext="50 pourcent Arrow"
          ></button>

          <div class="comparison-label label-left">Vue dispersée</div>
          <div class="comparison-label label-right">Arrow</div>
        </div>
      </div>

      <p class="comparison-subtitle">D'une lecture dispersée à une fiche étudiant exploitable</p>

      <div class="brutal-entry">
        <p class="brutal-entry__lead">Vous reconnaissez ces irritants dans votre suivi actuel ?</p>
        <button type="button" class="brutal-mode-cta" data-open-modal="brutalModeModal" data-track="home_brutal_mode">
          <span class="brutal-cta-text">Voir les irritants fréquents</span>
          <span class="brutal-cta-icon">↗</span>
        </button>
      </div>
    </div>

    <section class="home-section-head home-section-head--compact">
      <p class="eyebrow">Positionnement</p>
      <h2>Pensé pour les équipes qui doivent suivre, prouver et décider.</h2>
      <p>
        Arrow aide les établissements qui doivent retrouver vite une absence, préparer un bulletin,
        documenter un échange ou partager une preuve fiable autour du parcours étudiant.
      </p>
    </section>

    <div class="cyber-grid cyber-grid--compact">
      <div class="cyber-card cyber-card--student">
        <div class="cyber-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <rect x="14" y="14" width="36" height="36" rx="12" stroke="currentColor" stroke-width="1.8"/>
            <circle cx="32" cy="27" r="6" stroke="currentColor" stroke-width="1.8"/>
            <path d="M22 43C24.2 37.8 28 35 32 35C36 35 39.8 37.8 42 43" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="cyber-title">FICHE ÉTUDIANT</h3>
        <p class="cyber-desc">Absences, notes, documents et historique dans une même lecture.</p>
      </div>

      <div class="cyber-card cyber-card--attendance">
        <div class="cyber-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <path d="M18 42L26 34L31 39L44 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M18 20H46" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" opacity="0.45"/>
            <path d="M18 28H34" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" opacity="0.45"/>
            <circle cx="44" cy="24" r="4" fill="currentColor"/>
          </svg>
        </div>
        <h3 class="cyber-title">ABSENCES</h3>
        <p class="cyber-desc">Alertes et assiduité lisibles sans changer de fenêtre.</p>
      </div>

      <div class="cyber-card cyber-card--results">
        <div class="cyber-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <rect x="18" y="14" width="24" height="30" rx="6" stroke="currentColor" stroke-width="1.8"/>
            <path d="M24 24H36" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M24 31H36" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" opacity="0.55"/>
            <path d="M24 38H32" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" opacity="0.55"/>
            <path d="M42 21L46 25L42 29" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="cyber-title">NOTES & BULLETINS</h3>
        <p class="cyber-desc">Résultats, évaluations et bulletins reliés plus clairement.</p>
      </div>

      <div class="cyber-card cyber-card--documents">
        <div class="cyber-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <path d="M18 24C18 20.6863 20.6863 18 24 18H30L34 22H40C43.3137 22 46 24.6863 46 28V40C46 43.3137 43.3137 46 40 46H24C20.6863 46 18 43.3137 18 40V24Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M27 33L31 37L38 29" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="cyber-title">DOCUMENTS & PREUVES</h3>
        <p class="cyber-desc">Pièces, commentaires et preuves utiles retrouvés plus vite.</p>
      </div>
    </div>

    <div class="cyber-cta">
      <a href="/tarifs" class="cyber-button" data-track="home_beta_details" style="text-decoration: none; display: inline-block;">Comprendre la bêta</a>
    </div>
  </div>

  <div
    id="brutalModeModal"
    class="modal-overlay brutal-modal-overlay"
    style="display: none;"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="brutalModeModalTitle"
  >
    <div class="brutal-modal-container">
      <button
        class="brutal-modal-close"
        type="button"
        data-close-modal="brutalModeModal"
        aria-label="Fermer"
      >×</button>
      <div class="brutal-modal-content">
        <section class="brutal-hero">
          <div class="brutal-hero-bg"></div>
          <div class="brutal-hero-content">
            <p class="brutal-hero-eyebrow">Diagnostic terrain</p>
            <h2 id="brutalModeModalTitle" class="brutal-hero-title">
              Les irritants qui ralentissent<br>
              le suivi étudiant au quotidien
            </h2>
            <p class="brutal-hero-subtitle">
              Avant de parler solution, il faut nommer le problème : informations dispersées,
              exports fragiles, preuves difficiles à retrouver et manque de lecture partagée.
            </p>
          </div>
        </section>

        <section class="brutal-section brutal-problems-section">
          <h2 class="brutal-section-title">Les irritants que tout le monde connaît</h2>
          <p class="brutal-section-subtitle">Ceux qu'on finit par accepter, alors qu'ils ralentissent toute l'équipe.</p>

          <div class="brutal-problems-grid">
            <div class="brutal-problem-card">
              <div class="brutal-problem-icon">INFO</div>
              <h3 class="brutal-problem-title">Information trop dispersée</h3>
              <p class="brutal-problem-desc">
                Onglets imbriqués, libellés techniques, actions cachées : le moindre export peut demander trop de contexte.
              </p>
              <div class="brutal-problem-quote">
                "Je sais que l'info existe quelque part, mais je ne sais plus dans quel écran."
              </div>
            </div>

            <div class="brutal-problem-card">
              <div class="brutal-problem-icon">DOC</div>
              <h3 class="brutal-problem-title">Bulletins longs à préparer</h3>
              <p class="brutal-problem-desc">
