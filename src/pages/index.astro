                      <td>14/11/2025</td>
                    </tr>
                    <tr>
                      <td><span class="hp-icon hp-icon-pink">▼</span> SIMON Chloé</td>
                      <td>19/11/2007</td>
                      <td><span class="hp-icon hp-icon-pink">♀</span></td>
                      <td><span class="hp-email-link">chloe.simon@email.com</span></td>
                      <td>20h00 (7)</td>
                      <td>00h00</td>
                      <td><span class="hp-status">Début d'année</span></td>
                      <td>30/11/2025</td>
                    </tr>
                    <tr>
                      <td><span class="hp-icon hp-icon-pink">▼</span> LAURENT Hugo</td>
                      <td>31/05/2007</td>
                      <td><span class="hp-icon hp-icon-blue">♂</span></td>
                      <td><span class="hp-email-link">hugo.laurent@email.com</span></td>
                      <td>98h00 (33)</td>
                      <td>21h00 (7)</td>
                      <td><span class="hp-status">Début d'année</span></td>
                      <td>14/11/2025</td>
                    </tr>
                    <tr>
                      <td><span class="hp-icon hp-icon-pink">▼</span> LEFEVRE Camille</td>
