---
import BaseLayout from '../layouts/BaseLayout.astro'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Arrow',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description:
    "Arrow centralise les absences, les notes, les bulletins, les documents et les preuves de suivi dans un espace plus clair pour les équipes pédagogiques et scolarité.",
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/LimitedAvailability',
    category: 'Beta',
  },
}
---
<BaseLayout
  title="Arrow — Le suivi étudiant plus clair"
  description="Arrow centralise absences, notes, bulletins, documents et commentaires utiles dans un espace plus clair pour les équipes pédagogiques et scolarité."
  activePage="accueil"
  jsonLd={jsonLd}
>
  <link rel="stylesheet" href="/styles/pages/index.css" slot="head">

  <div class="main-container home-page">
    <section class="hero-orbit">
      <div class="hero-orbit__text">
        <p class="eyebrow">Pour écoles supérieures, CFA et équipes scolarité</p>
        <h1>
          Le suivi étudiant
          <span class="text-primary text-glow">centralisé</span>
          pour décider plus vite
        </h1>
        <p class="hero-orbit__desc">
          Arrow réunit absences, notes, bulletins, documents et commentaires dans une vue claire par étudiant,
          pour aider les équipes pédagogiques et scolarité à suivre, relancer et justifier sans multiplier les exports.
        </p>
        <div class="hero-orbit__cta">
          <a href="/contact" data-open-modal="betaAccessModal" class="btn-primary" data-track="home_demo">Demander une démo</a>
          <a href="#difference" class="btn-ghost" data-track="home_difference">Voir la différence</a>
        </div>
      </div>

      <div class="orbit-system" aria-hidden="true">
        <div class="orbit-ring"></div>
        <div class="orbit-ring"></div>
        <div class="orbit-ring"></div>
        <div class="orbit-sphere"></div>

        <div class="orbit-card orbit-card--top-left">
          <div class="orbit-card-value">ABSENCES</div>
          <div class="orbit-card-label">Alertes</div>
        </div>
        <div class="orbit-card orbit-card--top-right">
          <div class="orbit-card-value">NOTES</div>
          <div class="orbit-card-label">Bulletins</div>
        </div>
        <div class="orbit-card orbit-card--bottom-left">
          <div class="orbit-card-value">DOCS</div>
          <div class="orbit-card-label">Preuves</div>
        </div>
        <div class="orbit-card orbit-card--bottom-right">
          <div class="orbit-card-value">SUIVIS</div>
          <div class="orbit-card-label">Commentaires</div>
        </div>

        <div class="orbit-cards-grid">
          <div class="orbit-card">
            <div class="orbit-card-value">ABSENCES</div>
            <div class="orbit-card-label">Alertes</div>
          </div>
          <div class="orbit-card">
            <div class="orbit-card-value">NOTES</div>
            <div class="orbit-card-label">Bulletins</div>
          </div>
          <div class="orbit-card">
            <div class="orbit-card-value">DOCS</div>
            <div class="orbit-card-label">Preuves</div>
          </div>
          <div class="orbit-card">
            <div class="orbit-card-value">SUIVIS</div>
            <div class="orbit-card-label">Commentaires</div>
          </div>
        </div>
      </div>
    </section>

    <div class="hud-stats">
      <div class="stat-item">
        <div class="stat-value">1 fiche</div>
        <div class="stat-label">par étudiant</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">Moins</div>
        <div class="stat-label">d'exports dispersés</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">Suivi</div>
        <div class="stat-label">partagé par l'équipe</div>
      </div>
    </div>

    <div class="comparison-section" id="difference">
      <div class="comparison-header">
        <h2 class="comparison-title">
          <span class="comparison-title__old">SUIVI DISPERSÉ</span> vs <span class="comparison-title__arrow">ARROW</span>
        </h2>
        <p class="comparison-instruction">Comparez une vue dispersée et Arrow</p>
