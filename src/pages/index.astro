---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Arrow — Plateforme de gestion éducative" activePage="accueil">
  <link rel="stylesheet" href="/styles/pages/index.css" slot="head">
  <div class="main-container">
    <!-- Hero Orbite -->
    <section class="hero-orbit">
      <div class="hero-orbit__text">
        <p class="eyebrow">Plateforme éducative next-gen</p>
        <h1>Gérez vos élèves <span class="text-primary text-glow">sans effort</span></h1>
        <p class="hero-orbit__desc">Arrow centralise la gestion de vos formations, de vos élèves et de vos résultats dans une interface claire et rapide.</p>
        <div class="hero-orbit__cta">
          <a href="/contact" class="btn-primary">Démarrer gratuitement</a>
          <a href="/fonctionnalites" class="btn-ghost">Voir les fonctionnalités</a>
        </div>
      </div>
      <div class="orbit-system" aria-hidden="true">
        <div class="orbit-ring"></div>
        <div class="orbit-ring"></div>
        <div class="orbit-ring"></div>
        <div class="orbit-sphere"></div>
        <!-- Orbit cards -->
        <div class="orbit-card orbit-card--top-left">
          <div class="orbit-card-value">99.9%</div>
          <div class="orbit-card-label">Uptime</div>
        </div>
        <div class="orbit-card orbit-card--top-right">
          <div class="orbit-card-value">∞</div>
          <div class="orbit-card-label">Élèves</div>
        </div>
        <div class="orbit-card orbit-card--bottom-left">
          <div class="orbit-card-value">24/7</div>
          <div class="orbit-card-label">Support</div>
        </div>
        <div class="orbit-card orbit-card--bottom-right">
          <div class="orbit-card-value">+89%</div>
          <div class="orbit-card-label">Gain de temps</div>
        </div>
        <!-- Mobile fallback grid -->
        <div class="orbit-cards-grid">
          <div class="orbit-card"><div class="orbit-card-value">99.9%</div><div class="orbit-card-label">Uptime</div></div>
          <div class="orbit-card"><div class="orbit-card-value">∞</div><div class="orbit-card-label">Élèves</div></div>
          <div class="orbit-card"><div class="orbit-card-value">24/7</div><div class="orbit-card-label">Support</div></div>
          <div class="orbit-card"><div class="orbit-card-value">+89%</div><div class="orbit-card-label">Gain</div></div>
        </div>
      </div>
    </section>

    <!-- HUD Stats Centered Above Cards -->
    <div class="hud-stats">
      <div class="stat-item">
        <div class="stat-value">99.9%</div>
        <div class="stat-label">du temps éveillé</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">24/7</div>
        <div class="stat-label">Support</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">∞</div>
        <div class="stat-label">Élèves</div>
