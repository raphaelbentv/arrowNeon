                      <td>35h00 (12)</td>
                      <td>03h00 (1)</td>
                      <td><span class="hp-status">Début d'année</span></td>
                      <td></td>
                    </tr>
                    <tr>
                      <td><span class="hp-icon hp-icon-pink">▼</span> DURAND Emma</td>
                      <td>22/06/2007</td>
                      <td><span class="hp-icon hp-icon-pink">♀</span></td>
                      <td><span class="hp-email-link">emma.durand@email.com</span></td>
                      <td>06h00 (2)</td>
                      <td>00h00</td>
                      <td><span class="hp-status">Début d'année</span></td>
                      <td>30/11/2025</td>
                    </tr>
                    <tr>
                      <td><span class="hp-icon hp-icon-pink">▼</span> MOREAU Léo</td>
