---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout
  title="Démo interactive — Arrow"
  description="Explorez Arrow sans vous connecter. Visualisez les 3 espaces de la plateforme : Administration, Intervenant et Étudiant."
  activePage="demo"
>
  <link rel="stylesheet" href="/styles/pages/demo.css" slot="head">

  <div class="main-container demo-page">

    <div class="demo-page-header">
      <p class="eyebrow">Aperçu de la plateforme</p>
      <h1>Explorez Arrow sans vous connecter</h1>
      <p>Sélectionnez un espace pour voir l'interface correspondante. Les données affichées sont fictives — c'est un clone fidèle de l'app réelle.</p>
    </div>

    <div class="demo-selector">
      <button class="demo-selector-btn active" data-space="admin" type="button">
        <span class="demo-selector-label">Administration</span>
        <span class="demo-selector-desc">Direction & scolarité</span>
      </button>
      <button class="demo-selector-btn" data-space="teacher" type="button">
        <span class="demo-selector-label">Intervenant</span>
        <span class="demo-selector-desc">Suivi pédagogique</span>
      </button>
      <button class="demo-selector-btn" data-space="student" type="button">
        <span class="demo-selector-label">Étudiant</span>
        <span class="demo-selector-desc">Espace personnel</span>
      </button>
    </div>

    <div class="demo-browser" id="demoBrowser" data-demo-theme="dark">
      <div class="demo-chrome">
        <div class="demo-chrome-dots">
          <span class="demo-chrome-dot"></span>
          <span class="demo-chrome-dot"></span>
          <span class="demo-chrome-dot"></span>
        </div>
        <div class="demo-chrome-url" id="demoUrl">arr0w.app/dashboard</div>
        <button class="demo-theme-toggle" id="demoThemeToggle" type="button" aria-label="Basculer thème clair/sombre">
          <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        </button>
      </div>

      <div class="demo-viewport" id="demoViewport">

        <!-- ══════════════════════════════════════════════
             ESPACE ADMIN
        ══════════════════════════════════════════════ -->
        <div class="demo-space active" id="space-admin">

          <header class="arr-header">
            <div class="arr-logo-block">
              <a href="https://arr0w.app/dashboard" target="_blank" rel="noopener" class="arr-logo">ARROW</a>
              <span class="arr-role-badge">Super admin</span>
              <span class="arr-school">Arrow demo campus</span>
            </div>
            <ul class="arr-nav">
              <li class="arr-nav-item active" data-admin-nav="dashboard">Mon espace</li>
              <li class="arr-nav-item arr-nav-dropdown" data-admin-nav-dropdown>
                <span class="arr-nav-label">Planning <svg class="arr-nav-caret" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span>
                <div class="arr-nav-menu">
                  <a class="arr-nav-menu-item" data-admin-nav="calendrier">Calendrier</a>
                  <a class="arr-nav-menu-item" data-admin-nav="planning-modules">Planning des modules</a>
                  <a class="arr-nav-menu-item" data-admin-nav="disponibilites">Disponibilités des intervenants</a>
                </div>
              </li>
              <li class="arr-nav-item arr-nav-dropdown" data-admin-nav-dropdown>
                <span class="arr-nav-label">Pédagogie <svg class="arr-nav-caret" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span>
                <div class="arr-nav-menu">
                  <a class="arr-nav-menu-item" data-admin-nav="classes">Classes</a>
                  <a class="arr-nav-menu-item" data-admin-nav="modules">Modules</a>
                  <a class="arr-nav-menu-item" data-admin-nav="evaluations">Évaluations</a>
                  <a class="arr-nav-menu-item" data-admin-nav="notes">Notes</a>
                  <div class="arr-nav-menu-sep">Bulletins</div>
                  <a class="arr-nav-menu-item" data-admin-nav="rapports">Rapports personnalisés</a>
                  <a class="arr-nav-menu-item" data-admin-nav="presences">Présences</a>
                  <a class="arr-nav-menu-item" data-admin-nav="budget">Budget de formation</a>
                </div>
              </li>
              <li class="arr-nav-item arr-nav-dropdown" data-admin-nav-dropdown>
                <span class="arr-nav-label">Utilisateurs <svg class="arr-nav-caret" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span>
                <div class="arr-nav-menu">
                  <a class="arr-nav-menu-item" data-admin-nav="students">Étudiants</a>
                  <a class="arr-nav-menu-item" data-admin-nav="intervenants">Intervenants</a>
                  <a class="arr-nav-menu-item" data-admin-nav="administrateurs">Administrateurs</a>
                </div>
              </li>
              <li class="arr-nav-item">Communication</li>
              <li class="arr-nav-item">Suivis</li>
              <li class="arr-nav-item">Paramètres</li>
            </ul>
            <div class="arr-header-actions">
              <button class="arr-icon-btn" aria-label="Recherche"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></button>
              <button class="arr-icon-btn" aria-label="Messages"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></button>
              <button class="arr-icon-btn profile" aria-label="Profil"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></button>
            </div>
          </header>

          <!-- ÉCRAN 1 : Dashboard admin -->
          <div class="arr-screen active" id="admin-screen-dashboard">
            <p class="arr-greeting">Bonjour <strong>Admin</strong></p>

            <div class="arr-tabs" id="admin-tabs">
              <button class="arr-tab active" data-admin-tab="synthese">Synthèse</button>
              <button class="arr-tab" data-admin-tab="planning">Planning</button>
              <button class="arr-tab" data-admin-tab="etudiants">Étudiants</button>
              <button class="arr-tab" data-admin-tab="intervenants">Intervenants</button>
              <button class="arr-tab" data-admin-tab="modules">Modules</button>
              <button class="arr-tab" data-admin-tab="presences">Présences</button>
              <button class="arr-tab" data-admin-tab="evaluations">Évaluations</button>
              <button class="arr-tab" data-admin-tab="exports">Exports</button>
            </div>

            <!-- Tab Synthèse -->
            <div class="arr-tab-panel active" id="admin-tab-synthese">
              <div class="arr-stats">
                <div class="arr-stat"><div class="arr-stat-label">Étudiants</div><div class="arr-stat-value blue">82</div></div>
                <div class="arr-stat"><div class="arr-stat-label">Intervenants</div><div class="arr-stat-value purple">12</div></div>
                <div class="arr-stat"><div class="arr-stat-label">Cohortes</div><div class="arr-stat-value cyan">6</div></div>
                <div class="arr-stat"><div class="arr-stat-label">Modules</div><div class="arr-stat-value orange">24</div></div>
                <div class="arr-stat"><div class="arr-stat-label">Évaluations</div><div class="arr-stat-value pink">15</div></div>
                <div class="arr-stat"><div class="arr-stat-label">Moyenne</div><div class="arr-stat-value green">13.4</div></div>
              </div>

              <div class="arr-section">
                <h3 class="arr-section-title">Points d'attention</h3>
                <div class="arr-alert">
                  <div class="arr-alert-info">
                    <span class="arr-alert-title">Inactifs 14j+</span>
                    <span class="arr-alert-desc">3 étudiant(s) sans activité depuis plus de 14 jours</span>
                  </div>
                  <span class="arr-alert-count">3</span>
                </div>
                <div class="arr-alert">
                  <div class="arr-alert-info">
                    <span class="arr-alert-title">Bulletins à valider</span>
                    <span class="arr-alert-desc">5 bulletins en attente de signature</span>
                  </div>
                  <span class="arr-alert-count">5</span>
                </div>
              </div>

              <div class="arr-two-col">
                <div class="arr-card">
                  <div class="arr-card-header">Présences</div>
                  <div class="arr-row" data-goto-profile>
                    <div>
                      <div class="arr-row-name">Sophie MARTIN</div>
                      <div class="arr-row-meta">BACH-MKT-2024 · Absence 14/05</div>
                    </div>
                    <span class="arr-badge warn">Non justifiée</span>
                  </div>
                  <div class="arr-row" data-goto-profile>
                    <div>
                      <div class="arr-row-name">Lucas DUBOIS</div>
                      <div class="arr-row-meta">BACH-RH-2024 · Absence 13/05</div>
                    </div>
                    <span class="arr-badge warn">En attente</span>
                  </div>
                  <div class="arr-row" data-goto-profile>
                    <div>
                      <div class="arr-row-name">Emma BERNARD</div>
                      <div class="arr-row-meta">MAST-FIN-2023 · Absence 12/05</div>
                    </div>
                    <span class="arr-badge ok">Justifiée</span>
                  </div>
                  <div class="arr-row" data-goto-profile>
                    <div>
                      <div class="arr-row-name">Thomas PETIT</div>
                      <div class="arr-row-meta">BACH-MKT-2024 · Absence 12/05</div>
                    </div>
                    <span class="arr-badge err">3e absence</span>
                  </div>
                </div>
                <div class="arr-card">
                  <div class="arr-card-header">Sessions récentes</div>
                  <div class="arr-row">
                    <div>
                      <div class="arr-row-name">Marketing Digital</div>
                      <div class="arr-row-meta">Lundi 13/05 · 09h–12h</div>
                    </div>
                    <span class="arr-badge ok">24/26</span>
                  </div>
                  <div class="arr-row">
                    <div>
                      <div class="arr-row-name">Droit du travail</div>
                      <div class="arr-row-meta">Lundi 13/05 · 14h–17h</div>
                    </div>
                    <span class="arr-badge info">18/20</span>
                  </div>
                  <div class="arr-row">
                    <div>
                      <div class="arr-row-name">Finance d'entreprise</div>
                      <div class="arr-row-meta">Vendredi 10/05 · 09h–13h</div>
                    </div>
                    <span class="arr-badge warn">21/24</span>
                  </div>
                  <div class="arr-row">
                    <div>
                      <div class="arr-row-name">Communication RH</div>
                      <div class="arr-row-meta">Vendredi 10/05 · 14h–17h</div>
                    </div>
                    <span class="arr-badge ok">20/20</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Tab Planning -->
            <div class="arr-tab-panel" id="admin-tab-planning">
              <div class="arr-planning">
                <div class="arr-planning-header">
                  <div class="arr-planning-title">Semaine du 20 au 24 mai 2026</div>
                  <div style="display:flex;gap:8px;">
                    <button class="arr-btn">◄</button>
                    <button class="arr-btn">Aujourd'hui</button>
                    <button class="arr-btn">►</button>
                  </div>
                </div>
                <div class="arr-planning-grid">
                  <div class="arr-planning-cell arr-planning-head"></div>
                  <div class="arr-planning-cell arr-planning-head">Lundi 20</div>
                  <div class="arr-planning-cell arr-planning-head">Mardi 21</div>
                  <div class="arr-planning-cell arr-planning-head">Mercredi 22</div>
                  <div class="arr-planning-cell arr-planning-head">Jeudi 23</div>
                  <div class="arr-planning-cell arr-planning-head">Vendredi 24</div>

                  <div class="arr-planning-cell arr-planning-time">09h</div>
                  <div class="arr-planning-cell"><div class="arr-planning-session">Marketing Digital<br><small>Bach-MKT · S. Bernier</small></div></div>
                  <div class="arr-planning-cell"></div>
                  <div class="arr-planning-cell"><div class="arr-planning-session purple">Stratégie<br><small>Bach-MKT · M. Durand</small></div></div>
                  <div class="arr-planning-cell"><div class="arr-planning-session green">Finance<br><small>Mast-FIN · L. Robin</small></div></div>
                  <div class="arr-planning-cell"><div class="arr-planning-session orange">Com. digitale<br><small>Bach-MKT · S. Bernier</small></div></div>

                  <div class="arr-planning-cell arr-planning-time">14h</div>
                  <div class="arr-planning-cell"><div class="arr-planning-session purple">Droit du travail<br><small>Bach-RH · P. Lemaire</small></div></div>
                  <div class="arr-planning-cell"><div class="arr-planning-session">Marketing Digital<br><small>Bach-MKT · S. Bernier</small></div></div>
                  <div class="arr-planning-cell"></div>
                  <div class="arr-planning-cell"><div class="arr-planning-session orange">Communication<br><small>Bach-MKT · C. Roy</small></div></div>
                  <div class="arr-planning-cell"></div>
                </div>
              </div>
            </div>

            <!-- Tab Étudiants -->
            <div class="arr-tab-panel" id="admin-tab-etudiants">
              <p class="arr-subtitle" style="margin-bottom:14px;">Aperçu de la liste — voir tous les étudiants pour la version complète.</p>
              <div class="arr-students-grid" id="admin-tab-students-grid">
                <div class="arr-student-card" data-admin-card-goto>
                  <div class="arr-student-top">
                    <div class="arr-avatar green">SM</div>
                    <div class="arr-student-info">
                      <div class="arr-student-name">Sophie MARTIN</div>
                      <div class="arr-student-email">s.martin@arrow.test</div>
                    </div>
                    <span class="arr-badge ok">Inscrite</span>
                  </div>
                </div>
                <div class="arr-student-card" data-admin-card-goto>
                  <div class="arr-student-top">
                    <div class="arr-avatar">LD</div>
                    <div class="arr-student-info">
                      <div class="arr-student-name">Lucas DUBOIS</div>
                      <div class="arr-student-email">l.dubois@arrow.test</div>
                    </div>
                    <span class="arr-badge ok">Inscrit</span>
                  </div>
                </div>
                <div class="arr-student-card" data-admin-card-goto>
                  <div class="arr-student-top">
                    <div class="arr-avatar purple">EB</div>
                    <div class="arr-student-info">
                      <div class="arr-student-name">Emma BERNARD</div>
                      <div class="arr-student-email">e.bernard@arrow.test</div>
                    </div>
                    <span class="arr-badge ok">Inscrite</span>
                  </div>
                </div>
              </div>
              <div style="text-align:center;margin-top:18px;">
                <button class="arr-btn" data-admin-nav="students">Voir tous les étudiants →</button>
              </div>
            </div>

            <!-- Tab Intervenants -->
            <div class="arr-tab-panel" id="admin-tab-intervenants">
              <table class="arr-table">
                <thead><tr><th>Intervenant</th><th>Modules</th><th>Étudiants suivis</th><th>Statut</th></tr></thead>
                <tbody>
                  <tr><td><strong>Sophie BERNIER</strong><div class="arr-row-meta">s.bernier@arrow.test</div></td><td>Marketing Digital · Com. digitale</td><td>45</td><td><span class="arr-badge ok">Actif</span></td></tr>
                  <tr><td><strong>Paul LEMAIRE</strong><div class="arr-row-meta">p.lemaire@arrow.test</div></td><td>Droit du travail</td><td>22</td><td><span class="arr-badge ok">Actif</span></td></tr>
                  <tr><td><strong>Laure ROBIN</strong><div class="arr-row-meta">l.robin@arrow.test</div></td><td>Finance d'entreprise</td><td>18</td><td><span class="arr-badge ok">Actif</span></td></tr>
                  <tr><td><strong>Marc DURAND</strong><div class="arr-row-meta">m.durand@arrow.test</div></td><td>Stratégie de marque</td><td>26</td><td><span class="arr-badge warn">Inactif 14j+</span></td></tr>
                </tbody>
              </table>
            </div>

            <!-- Tab Modules -->
            <div class="arr-tab-panel" id="admin-tab-modules">
              <table class="arr-table">
                <thead><tr><th>Module</th><th>Cohorte</th><th>Intervenant</th><th>Progression</th></tr></thead>
                <tbody>
                  <tr><td><strong>Marketing Digital</strong></td><td>BACH-MKT-2024</td><td>S. Bernier</td><td><span class="arr-badge ok">68%</span></td></tr>
                  <tr><td><strong>Droit du travail</strong></td><td>BACH-RH-2024</td><td>P. Lemaire</td><td><span class="arr-badge info">54%</span></td></tr>
                  <tr><td><strong>Finance d'entreprise</strong></td><td>MAST-FIN-2023</td><td>L. Robin</td><td><span class="arr-badge warn">42%</span></td></tr>
                  <tr><td><strong>Stratégie de marque</strong></td><td>BACH-MKT-2024</td><td>M. Durand</td><td><span class="arr-badge ok">76%</span></td></tr>
                  <tr><td><strong>Communication RH</strong></td><td>BACH-RH-2024</td><td>C. Roy</td><td><span class="arr-badge info">61%</span></td></tr>
                </tbody>
              </table>
            </div>

            <!-- Tab Présences -->
            <div class="arr-tab-panel" id="admin-tab-presences">
              <div class="arr-stats" style="grid-template-columns:repeat(3,1fr);">
                <div class="arr-stat"><div class="arr-stat-label">Taux présence</div><div class="arr-stat-value green">87%</div></div>
                <div class="arr-stat"><div class="arr-stat-label">Absences ce mois</div><div class="arr-stat-value orange">14</div></div>
                <div class="arr-stat"><div class="arr-stat-label">Non justifiées</div><div class="arr-stat-value pink">6</div></div>
              </div>
              <div class="arr-card">
                <div class="arr-card-header">Top absents</div>
                <div class="arr-row"><div><div class="arr-row-name">Thomas PETIT</div><div class="arr-row-meta">BACH-MKT-2024 · 3 abs.</div></div><span class="arr-badge err">À signaler</span></div>
                <div class="arr-row"><div><div class="arr-row-name">Julie ROBERT</div><div class="arr-row-meta">BACH-MKT-2024 · 2 abs.</div></div><span class="arr-badge warn">À surveiller</span></div>
                <div class="arr-row"><div><div class="arr-row-name">Marc DURAND</div><div class="arr-row-meta">BACH-RH-2024 · 2 abs.</div></div><span class="arr-badge warn">À surveiller</span></div>
              </div>
            </div>

            <!-- Tab Évaluations -->
            <div class="arr-tab-panel" id="admin-tab-evaluations">
              <table class="arr-table">
                <thead><tr><th>Évaluation</th><th>Module</th><th>Date</th><th>Statut</th></tr></thead>
                <tbody>
                  <tr><td><strong>Étude de cas — Marque</strong></td><td>Stratégie de marque</td><td>25/05/2026</td><td><span class="arr-badge warn">À corriger</span></td></tr>
                  <tr><td><strong>Examen mi-parcours</strong></td><td>Droit du travail</td><td>03/06/2026</td><td><span class="arr-badge info">À venir</span></td></tr>
                  <tr><td><strong>Rapport RH</strong></td><td>Communication RH</td><td>10/06/2026</td><td><span class="arr-badge info">À venir</span></td></tr>
                </tbody>
              </table>
            </div>

            <!-- Tab Exports -->
            <div class="arr-tab-panel" id="admin-tab-exports">
              <div class="arr-empty">
                <span class="arr-empty-icon">📤</span>
                Préparez des exports CSV/PDF des bulletins, absences et évaluations.
              </div>
            </div>
          </div>

          <!-- ÉCRAN 2 : Liste étudiants -->
          <div class="arr-screen" id="admin-screen-students">
            <div class="arr-page-header">
              <div>
                <h1 class="arr-h1">Étudiants</h1>
                <p class="arr-subtitle">Gestion des étudiant(e)s et suivi académique</p>
              </div>
              <div class="arr-page-actions">
                <button class="arr-btn">Actualiser</button>
                <button class="arr-btn">Exporter</button>
                <button class="arr-btn arr-btn-primary">+ Nouvel étudiant</button>
              </div>
            </div>

            <div class="arr-mini-stats">
              <div class="arr-mini-stat"><div class="arr-mini-stat-label">Total étudiants</div><div class="arr-mini-stat-val">82</div></div>
              <div class="arr-mini-stat"><div class="arr-mini-stat-label">Inscrits</div><div class="arr-mini-stat-val">44</div></div>
              <div class="arr-mini-stat"><div class="arr-mini-stat-label">En attente</div><div class="arr-mini-stat-val">38</div></div>
              <div class="arr-mini-stat"><div class="arr-mini-stat-label">Diplômés</div><div class="arr-mini-stat-val">0</div></div>
              <div class="arr-mini-stat dark"><div class="arr-mini-stat-label">Initial</div><div class="arr-mini-stat-val">59</div></div>
              <div class="arr-mini-stat dark"><div class="arr-mini-stat-label">Alternance</div><div class="arr-mini-stat-val green">23</div></div>
            </div>

            <div class="arr-toolbar">
              <div class="arr-view-toggle">
                <button class="arr-view-btn active">Grille</button>
                <button class="arr-view-btn">Liste</button>
              </div>
              <input type="text" class="arr-search" id="studentSearch" placeholder="Rechercher un étudiant...">
            </div>

            <div class="arr-students-grid" id="studentsGrid">
              <div class="arr-student-card" data-name="Sophie MARTIN" data-goto-detail="emma">
                <div class="arr-student-top">
                  <div class="arr-avatar green">SM</div>
                  <div class="arr-student-info">
                    <div class="arr-student-name">Sophie MARTIN</div>
                    <div class="arr-student-email">s.martin@arrow.test</div>
                  </div>
                  <span class="arr-badge ok">Inscrite</span>
                </div>
                <div class="arr-student-meta">
                  <div class="arr-meta-cell"><div class="arr-meta-cell-label">Formation</div><div class="arr-meta-cell-val">BACH-MKT-2024</div></div>
                  <div class="arr-meta-cell"><div class="arr-meta-cell-label">Présence</div><div class="arr-meta-cell-val">92%</div></div>
                </div>
              </div>
              <div class="arr-student-card" data-name="Lucas DUBOIS" data-goto-detail="emma">
