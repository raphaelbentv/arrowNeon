                <div class="arr-planning-cell arr-planning-head">Lundi 20</div>
                <div class="arr-planning-cell arr-planning-head">Mardi 21</div>
                <div class="arr-planning-cell arr-planning-head">Mercredi 22</div>
                <div class="arr-planning-cell arr-planning-head">Jeudi 23</div>
                <div class="arr-planning-cell arr-planning-head">Vendredi 24</div>

                <div class="arr-planning-cell arr-planning-time">09h</div>
                <div class="arr-planning-cell"><div class="arr-planning-session">Marketing Digital<br><small>Salle B3</small></div></div>
                <div class="arr-planning-cell"></div>
                <div class="arr-planning-cell"><div class="arr-planning-session purple">Marketing Digital<br><small>Salle B3</small></div></div>
                <div class="arr-planning-cell"><div class="arr-planning-session green">Finance<br><small>Amphi C</small></div></div>
                <div class="arr-planning-cell"><div class="arr-planning-session orange">Com. digitale<br><small>Amphi C</small></div></div>

                <div class="arr-planning-cell arr-planning-time">14h</div>
                <div class="arr-planning-cell"><div class="arr-planning-session purple">Droit du travail<br><small>Salle A2</small></div></div>
                <div class="arr-planning-cell"></div>
                <div class="arr-planning-cell"></div>
                <div class="arr-planning-cell"><div class="arr-planning-session orange">Stratégie marque<br><small>Salle A1</small></div></div>
                <div class="arr-planning-cell"></div>
              </div>
            </div>
          </div>

        </div>

        <!-- Toast -->
        <div class="arr-toast" id="arrToast">Appel validé !</div>

      </div>
    </div>

    <div class="demo-cta">
      <p>Vous voulez voir Arrow sur vos données réelles ?</p>
      <a href="/contact" data-open-modal="betaAccessModal" class="btn-primary" data-track="demo_page_cta">Demander une démo</a>
    </div>

  </div>

  <script>
    // ═══════════════════════════════════════════
    // STATE & UTILS
    // ═══════════════════════════════════════════
    const $ = (s, c = document) => c.querySelector(s);
    const $$ = (s, c = document) => Array.from(c.querySelectorAll(s));

    const urls = {
      admin: { dashboard: 'arr0w.app/admin', students: 'arr0w.app/admin/students', detail: 'arr0w.app/admin/students/emma-bernard' },
      teacher: { panel: 'arr0w.app/teacher', appel: 'arr0w.app/teacher/sessions/strat/appel' },
      student: { dashboard: 'arr0w.app/student', notes: 'arr0w.app/student/notes', planning: 'arr0w.app/student/planning' },
    };

    function updateUrl(space, screen) {
      $('#demoUrl').textContent = urls[space]?.[screen] || 'arr0w.app';
    }

    // ═══════════════════════════════════════════
    // THEME TOGGLE (dark par défaut)
    // ═══════════════════════════════════════════
    const browser = $('#demoBrowser');
    const storedTheme = localStorage.getItem('demo-theme');
    if (storedTheme === 'light') browser.dataset.demoTheme = 'light';

    $('#demoThemeToggle')?.addEventListener('click', () => {
      const next = browser.dataset.demoTheme === 'dark' ? 'light' : 'dark';
      browser.dataset.demoTheme = next;
      localStorage.setItem('demo-theme', next);
    });

    // ═══════════════════════════════════════════
    // SPACE SWITCHER
    // ═══════════════════════════════════════════
    $$('.demo-selector-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const space = btn.dataset.space;
        $$('.demo-selector-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        $$('.demo-space').forEach((s) => s.classList.remove('active'));
        $('#space-' + space).classList.add('active');

        const firstScreen = space === 'admin' ? 'dashboard' : space === 'teacher' ? 'panel' : 'dashboard';
        updateUrl(space, firstScreen);
        $('#demoViewport').scrollTop = 0;
      });
    });

    // ═══════════════════════════════════════════
    // ADMIN — NAV + TABS + SCREENS
    // ═══════════════════════════════════════════
    // Mapping écran → libellé du parent de nav à activer (Mon espace, Planning, Pédagogie, Utilisateurs)
    const adminScreenToNavLabel = {
      dashboard: 'Mon espace',
      calendrier: 'Planning',
      'planning-modules': 'Planning',
      disponibilites: 'Planning',
      classes: 'Pédagogie',
      modules: 'Pédagogie',
      evaluations: 'Pédagogie',
      notes: 'Pédagogie',
      rapports: 'Pédagogie',
      presences: 'Pédagogie',
      budget: 'Pédagogie',
      students: 'Utilisateurs',
      detail: 'Utilisateurs',
      intervenants: 'Utilisateurs',
      administrateurs: 'Utilisateurs',
    };

    // Liste des écrans réellement implémentés (pour fallback)
    const adminAvailableScreens = new Set([
      'dashboard', 'students', 'detail',
      'calendrier', 'planning-modules', 'classes', 'intervenants', 'administrateurs',
    ]);

    const adminUrlMap = {
      dashboard: 'arr0w.app/admin',
      students: 'arr0w.app/admin/students',
      detail: 'arr0w.app/admin/students/emma-bernard',
      calendrier: 'arr0w.app/admin/planning/calendrier',
      'planning-modules': 'arr0w.app/admin/planning/modules',
      disponibilites: 'arr0w.app/admin/planning/disponibilites',
      classes: 'arr0w.app/admin/pedagogie/classes',
      modules: 'arr0w.app/admin/pedagogie/modules',
      evaluations: 'arr0w.app/admin/pedagogie/evaluations',
      notes: 'arr0w.app/admin/pedagogie/notes',
      rapports: 'arr0w.app/admin/pedagogie/rapports',
      presences: 'arr0w.app/admin/pedagogie/presences',
      budget: 'arr0w.app/admin/pedagogie/budget',
      intervenants: 'arr0w.app/admin/users/intervenants',
      administrateurs: 'arr0w.app/admin/users/administrateurs',
    };

    function showAdminScreen(name) {
      // Fallback : si l'écran n'existe pas (modules, notes, etc.), on retombe sur le dashboard tab correspondant
      const target = adminAvailableScreens.has(name) ? name : 'dashboard';
      $$('#space-admin .arr-screen').forEach((s) => s.classList.remove('active'));
      $('#admin-screen-' + target)?.classList.add('active');

      // Reset des items de nav (top-level seulement, pas les items de menu)
      $$('#space-admin > .arr-header .arr-nav > .arr-nav-item').forEach((n) => n.classList.remove('active'));
      const navLabel = adminScreenToNavLabel[name] || 'Mon espace';
      $$('#space-admin > .arr-header .arr-nav > .arr-nav-item').forEach((n) => {
        const lbl = (n.querySelector('.arr-nav-label')?.textContent || n.textContent || '').trim();
        if (lbl.startsWith(navLabel)) n.classList.add('active');
      });

      // Si fallback dashboard depuis un item du dropdown Pédagogie (ex: modules → tab modules)
      const dashboardTabMap = {
        presences: 'presences',
        evaluations: 'evaluations',
        notes: 'evaluations',
        modules: 'modules',
        rapports: 'exports',
        budget: 'exports',
        disponibilites: 'planning',
      };
      if (!adminAvailableScreens.has(name) && dashboardTabMap[name]) {
        const tabName = dashboardTabMap[name];
        $$('#admin-tabs .arr-tab').forEach((t) => t.classList.remove('active'));
        $(`#admin-tabs .arr-tab[data-admin-tab="${tabName}"]`)?.classList.add('active');
        $$('#admin-screen-dashboard .arr-tab-panel').forEach((p) => p.classList.remove('active'));
        $('#admin-tab-' + tabName)?.classList.add('active');
      }

      $('#demoUrl').textContent = adminUrlMap[name] || adminUrlMap[target] || 'arr0w.app';
      $('#demoViewport').scrollTop = 0;
    }

    // Sidebar / nav admin (cliquer un item de nav top-level ou un item de menu)
    $$('#space-admin [data-admin-nav]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        showAdminScreen(el.dataset.adminNav);
        // Fermer dropdowns ouverts
        $$('#space-admin .arr-nav-dropdown.open').forEach((d) => d.classList.remove('open'));
      });
    });

    // Dropdowns admin nav (click pour toggle, hover géré en CSS)
    $$('#space-admin .arr-nav-dropdown').forEach((d) => {
      d.addEventListener('click', (e) => {
        // Si on a cliqué sur un item de menu, ne pas re-toggler (laisser le handler ci-dessus gérer)
        if (e.target.closest('.arr-nav-menu-item')) return;
        e.stopPropagation();
        const wasOpen = d.classList.contains('open');
        $$('#space-admin .arr-nav-dropdown.open').forEach((x) => x.classList.remove('open'));
        if (!wasOpen) d.classList.add('open');
      });
    });
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.arr-nav-dropdown')) {
        $$('#space-admin .arr-nav-dropdown.open').forEach((d) => d.classList.remove('open'));
      }
    });

    // Tabs admin dashboard
    $$('#admin-tabs .arr-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        $$('#admin-tabs .arr-tab').forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        const name = tab.dataset.adminTab;
        $$('#admin-screen-dashboard .arr-tab-panel').forEach((p) => p.classList.remove('active'));
        $('#admin-tab-' + name)?.classList.add('active');
      });
    });

    // Lignes absences → fiche
    $$('#space-admin [data-goto-profile]').forEach((row) => {
      row.addEventListener('click', () => showAdminScreen('detail'));
    });

    // Cartes étudiants → fiche
    $$('#space-admin [data-goto-detail]').forEach((card) => {
      card.addEventListener('click', () => showAdminScreen('detail'));
    });
    // Cartes mini liste dans Tab Étudiants
    $$('#admin-tab-students-grid [data-admin-card-goto]').forEach((card) => {
      card.addEventListener('click', () => showAdminScreen('detail'));
    });

    // Back fiche
    $$('#space-admin [data-admin-back]').forEach((b) => {
      b.addEventListener('click', () => showAdminScreen(b.dataset.adminBack));
    });

    // Tabs fiche détail
    $$('#detail-tabs .arr-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        $$('#detail-tabs .arr-tab').forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        const name = tab.dataset.detailTab;
        $$('#admin-screen-detail .arr-tab-panel').forEach((p) => p.classList.remove('active'));
        $('#detail-tab-' + name)?.classList.add('active');
      });
    });

    // Recherche étudiants
    $('#studentSearch')?.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      $$('#studentsGrid .arr-student-card').forEach((card) => {
        const name = (card.dataset.name || '').toLowerCase();
        card.style.display = !q || name.includes(q) ? '' : 'none';
      });
    });

    // ═══════════════════════════════════════════
    // ADMIN — CALENDRIER (toggle Semaine / Mois)
    // ═══════════════════════════════════════════
    $$('#admin-screen-calendrier [data-cal-view-btn]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.calViewBtn;
        const scope = $('#admin-screen-calendrier');
        if (!scope) return;
        // Met à jour pill active
        $$('#admin-screen-calendrier [data-cal-view-btn]').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        scope.dataset.calView = view;

        const isMonth = view === 'mois';
        const isWeek = view === 'semaine';
        const showWeek = isWeek;
        const showMonth = isMonth;

        // Sub-titles
        $('[data-cal-sub-week]', scope).hidden = !showWeek;
        $('[data-cal-sub-month]', scope).hidden = !showMonth;

        // Date labels
        $('[data-cal-date-week]', scope).hidden = !showWeek;
        $('[data-cal-date-month]', scope).hidden = !showMonth;

        // Bandes
        $('[data-cal-band-week]', scope).hidden = !showWeek;
        $('[data-cal-band-month]', scope).hidden = !showMonth;

        // Vues principales
        $('[data-cal-view-pane="semaine"]', scope).hidden = !showWeek;
        $('[data-cal-view-pane="mois"]', scope).hidden = !showMonth;

        // Pour les autres vues (jour, année, liste), on affiche la semaine par défaut
        if (!isMonth && !isWeek) {
          $('[data-cal-sub-week]', scope).hidden = false;
          $('[data-cal-date-week]', scope).hidden = false;
          $('[data-cal-band-week]', scope).hidden = false;
          $('[data-cal-view-pane="semaine"]', scope).hidden = false;
        }
      });
    });

    // ═══════════════════════════════════════════
    // ADMIN — RECHERCHE CLASSES
    // ═══════════════════════════════════════════
    $('#classesSearch')?.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      let visible = 0;
      $$('#classesGrid .arr-class-card').forEach((card) => {
        const name = (card.dataset.className || '').toLowerCase();
        const match = !q || name.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible += 1;
      });
      const counter = $('#classesCount');
      if (counter) counter.textContent = visible;
    });

    // ═══════════════════════════════════════════
    // INTERVENANT — APPEL
    // ═══════════════════════════════════════════
    function showTeacherScreen(name) {
      $$('#space-teacher .arr-screen').forEach((s) => s.classList.remove('active'));
      $('#teacher-screen-' + name)?.classList.add('active');
      updateUrl('teacher', name);
      $('#demoViewport').scrollTop = 0;
    }

    $$('#space-teacher [data-teacher-appel]').forEach((b) => {
      b.addEventListener('click', () => showTeacherScreen('appel'));
    });
    $$('#space-teacher [data-teacher-back]').forEach((b) => {
      b.addEventListener('click', () => showTeacherScreen(b.dataset.teacherBack));
    });

    // Toggle présent/absent
    function updatePresentCount() {
      const total = $$('#appelList .arr-appel-row').length;
      const present = $$('#appelList .arr-appel-btn.active.present').length;
      $('#presentCount').textContent = present;
      $('.arr-appel-counter').innerHTML = `<span id="presentCount">${present}</span> / ${total}`;
    }

    $$('#appelList .arr-appel-row').forEach((row) => {
      const buttons = $$('.arr-appel-btn', row);
      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((b) => {
            b.classList.remove('active', 'present', 'absent');
          });
          btn.classList.add('active', btn.dataset.status);
          updatePresentCount();
        });
      });
    });

    // Valider appel
    $('#validerAppel')?.addEventListener('click', () => {
      const toast = $('#arrToast');
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2400);
    });

    // ═══════════════════════════════════════════
    // ÉTUDIANT — NAV + TABS
    // ═══════════════════════════════════════════
    function showStudentScreen(name) {
      $$('#space-student .arr-screen').forEach((s) => s.classList.remove('active'));
      $('#student-screen-' + name)?.classList.add('active');
      updateUrl('student', name);
      $('#demoViewport').scrollTop = 0;
    }

    $$('#space-student [data-student-nav]').forEach((el) => {
      el.addEventListener('click', () => {
        const target = el.dataset.studentNav;
        // Map nav clicks: pedago → notes
        const screenMap = { dashboard: 'dashboard', notes: 'notes', planning: 'planning', pedago: 'notes' };
        showStudentScreen(screenMap[target] || 'dashboard');
      });
    });

    $$('#space-student [data-student-back]').forEach((b) => {
      b.addEventListener('click', () => showStudentScreen(b.dataset.studentBack));
    });

    // Filtres notes
    $$('#notes-tabs .arr-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        $$('#notes-tabs .arr-tab').forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.notesFilter;
        $$('#notesTbody tr').forEach((tr) => {
          tr.style.display = filter === 'all' || tr.dataset.module === filter ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
