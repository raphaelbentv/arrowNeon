---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout
  title="Merci — Demande bêta envoyée"
  description="Votre demande d'accès à la bêta Arrow a bien été envoyée."
>
  <div class="main-container" style="padding-bottom: 6rem;">
    <section class="card" style="max-width: 760px; margin: 8rem auto 0; padding: 2.5rem;">
      <p class="eyebrow">Demande envoyée</p>
      <h1 style="margin-bottom: 1rem;">Votre demande d'accès bêta a bien été transmise.</h1>
      <p style="max-width: 52ch; color: var(--muted-foreground); margin-bottom: 1.5rem;">
        Merci. Nous revenons vers vous à l'adresse indiquée dès que nous avons étudié votre demande.
      </p>
      <a href="/" class="btn-primary">Retour à l'accueil</a>
    </section>
  </div>
</BaseLayout>
