---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Pour qui — Arrow" activePage="pour-qui">
  <div class="main-container">
    <div class="cyber-header">
      <h1 class="cyber-logo">POUR QUI ?</h1>
      <p class="cyber-tagline">ARROW S'ADAPTE À TOUS LES TYPES D'ÉTABLISSEMENTS</p>
    </div>

    <div class="establishment-grid">
      <!-- Écoles -->
      <div class="establishment-card">
        <div class="establishment-icon">🏫</div>
        <h2 class="establishment-title">ÉCOLES</h2>
        <div class="establishment-content">
          <h3>Cas d'usage</h3>
          <ul>
            <li>Gestion complète des élèves de la maternelle au lycée</li>
            <li>Suivi pédagogique et administratif</li>
            <li>Communication avec les familles</li>
            <li>Génération automatique des bulletins</li>
            <li>Gestion des absences et retards</li>
          </ul>
          <h3>Avantages spécifiques</h3>
          <ul>
            <li>Interface adaptée aux différents niveaux</li>
            <li>Conformité avec les exigences académiques</li>
            <li>Export vers les systèmes académiques</li>
          </ul>
        </div>
      </div>

      <!-- Formations professionnelles -->
      <div class="establishment-card">
        <div class="establishment-icon">🎓</div>
        <h2 class="establishment-title">FORMATIONS PROFESSIONNELLES</h2>
        <div class="establishment-content">
          <h3>Cas d'usage</h3>
          <ul>
            <li>Gestion des parcours de formation</li>
            <li>Suivi des compétences et certifications</li>
            <li>Gestion des stages en entreprise</li>
            <li>Évaluation continue des apprenants</li>
            <li>Génération de certificats</li>
          </ul>
          <h3>Avantages spécifiques</h3>
          <ul>
            <li>Conformité Qualiopi intégrée</li>
            <li>Gestion des référentiels de compétences</li>
            <li>Suivi des financements (CPF, OPCO)</li>
          </ul>
        </div>
      </div>

      <!-- CFA -->
      <div class="establishment-card">
        <div class="establishment-icon">⚙️</div>
        <h2 class="establishment-title">CFA</h2>
        <div class="establishment-content">
          <h3>Cas d'usage</h3>
          <ul>
            <li>Gestion des contrats d'apprentissage</li>
            <li>Suivi alternance entreprise/CFA</li>
            <li>Coordination avec les maîtres d'apprentissage</li>
            <li>Évaluation des compétences en entreprise</li>
            <li>Gestion des examens et certifications</li>
          </ul>
          <h3>Avantages spécifiques</h3>
          <ul>
            <li>Interface dédiée aux entreprises partenaires</li>
            <li>Conformité avec la réglementation de l'apprentissage</li>
            <li>Export vers les systèmes de financement</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
